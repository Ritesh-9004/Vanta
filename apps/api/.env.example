# ── Vanta API — Environment Variables ──────────────────
# Copy this file to .env and fill in VALUES below.

# Server
PORT=4000
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:dev@localhost:5432/vanta

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,https://vantapm.vercel.app
